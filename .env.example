# MySQL 配置
DB_USER=root
DB_PASS=your_mysql_password

# WebDAV 网盘配置
WEBDAV_URL=https://your-webdav-url.com/dav
WEBDAV_USER=your_webdav_username
WEBDAV_PASS=your_webdav_password
WEBDAV_DIR=db_backups

# 备份保留份数
MAX_KEEP=3

# 本地临时目录
LOCAL_TEMP_DIR=/tmp/db_backups

# 日志文件
LOG_FILE=/var/log/db_backup.log
